{
  "name": "q-asker",
  "private": true,
  "version": "1.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite --mode dev",
    "remote": "vite --mode remote",
    "build": "vite build --mode prod",
    "lint": "eslint .",
    "preview": "vite preview --port 5173",
    "i18n:wrap": "i18n-wrapper -p \"src/**/*.{js,jsx,ts,tsx}\"",
    "i18n:extract": "i18n-extractor",
    "i18n:type": "i18n-type",
    "i18n:sync": "npm run i18n:wrap && npm run i18n:extract && npm run i18n:type",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.35.2",
    "i18nexus": "^3.4.1",
    "katex": "^0.16.38",
    "lucide-react": "^0.577.0",
    "motion": "^12.36.0",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "^4.8.69",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-ga4": "^2.1.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^9.2.1",
    "react-router-dom": "^7.6.0",
    "react-toastify": "^11.0.5",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "i18nexus-tools": "^2.5.0",
    "prettier": "^3.8.1",
    "shadcn": "^4.0.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vite-plugin-prerender": "^1.0.8"
  },
  "imports": {
    "#app/*": "./src/app/*",
    "#pages/*": "./src/pages/*/index.tsx",
    "#features/*": "./src/features/*/index.ts",
    "#entities/*": "./src/entities/*/index.ts",
    "#widgets/*": "./src/widgets/*/index.tsx",
    "#shared/*": "./src/shared/*/index.ts",
    "#shared/lib/*": "./src/shared/lib/*.ts",
    "#shared/i18n": "./src/shared/i18n/index.ts"
  }
}
